  "API_PURCHASECONTRACT_PROCESS_SRV_0002": {
   "kind": "service",
   "@cds.external": true,
   "@m.IsDefaultEntityContainer": "true",
   "@sap.message.scope.supported": "true",
   "@sap.supported.formats": "atom json xlsx"
  },
  "API_PURCHASECONTRACT_PROCESS_SRV_0002.A_PurCtrAccount": {
   "kind": "entity",
   "@cds.external": true,
   "@cds.persistence.skip": true,
   "@sap.deletable": "false",
   "@sap.content.version": "2",
   "@sap.label": "Purchase Contract Item Acc. Assignment",
   "elements": {
    "AccountAssignment": {
     "key": true,
     "type": "cds.String",
     "length": 30,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Account Assignment",
     "notNull": true
    },
    "PurchaseContractItem": {
     "key": true,
     "type": "cds.String",
     "length": 5,
     "@sap.display.format": "NonNegative",
     "@sap.label": "Item",
     "@sap.quickinfo": "Item Number of Purchasing Document",
     "notNull": true
    },
    "PurchaseContract": {
     "key": true,
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Purchasing Document",
     "@sap.quickinfo": "Purchasing Document Number",
     "notNull": true
    },
    "IsDeleted": {
     "type": "cds.Boolean",
     "@sap.label": "Deletion Indicator",
     "@sap.quickinfo": "Deletion Indicator: Purchasing Document Account Assignment"
    },
    "Quantity": {
     "type": "cds.Decimal",
     "precision": 13,
     "scale": 3,
     "@sap.unit": "OrderQuantityUnit",
     "@sap.label": "Quantity"
    },
    "OrderQuantityUnit": {
     "type": "cds.String",
     "length": 3,
     "@sap.label": "Order Unit",
     "@sap.quickinfo": "Purchase Order Unit of Measure",
     "@sap.semantics": "unit-of-measure"
    },
    "OrderQuantityUnitISOCode": {
     "type": "cds.String",
     "length": 3,
     "@sap.semantics": "unit-of-measure"
    },
    "MultipleAcctAssgmtDistrPercent": {
     "type": "cds.Decimal",
     "precision": 3,
     "scale": 1,
     "@sap.label": "Distribution (%)",
     "@sap.quickinfo": "Distribution percentage in the case of multiple acct assgt"
    },
    "PurgDocNetAmount": {
     "type": "cds.Decimal",
     "precision": 13,
     "scale": 3,
     "@sap.unit": "DocumentCurrency",
     "@sap.variable.scale": "true",
     "@sap.label": "Net Order Value",
     "@sap.quickinfo": "Net Order Value in PO Currency"
    },
    "DocumentCurrency": {
     "type": "cds.String",
     "length": 5,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Currency",
     "@sap.quickinfo": "Currency Key",
     "@sap.semantics": "currency-code"
    },
    "GLAccount": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "G/L Account",
     "@sap.quickinfo": "G/L Account Number"
    },
    "BusinessArea": {
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Business Area"
    },
    "CostCenter": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Cost Center"
    },
    "SalesOrder": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "SD Document",
     "@sap.quickinfo": "Sales and Distribution Document Number"
    },
    "SalesOrderItem": {
     "type": "cds.String",
     "length": 6,
     "@sap.display.format": "NonNegative",
     "@sap.label": "Item",
     "@sap.quickinfo": "Sales Document Item"
    },
    "SalesOrderScheduleLine": {
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "NonNegative",
     "@sap.label": "Schedule Line Number"
    },
    "MasterFixedAsset": {
     "type": "cds.String",
     "length": 12,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Asset",
     "@sap.quickinfo": "Main Asset Number"
    },
    "FixedAsset": {
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Subnumber",
     "@sap.quickinfo": "Asset Subnumber"
    },
    "OrderID": {
     "type": "cds.String",
     "length": 12,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Order",
     "@sap.quickinfo": "Order Number"
    },
    "GoodsRecipientName": {
     "type": "cds.String",
     "length": 12,
     "@sap.label": "Goods Recipient"
    },
    "UnloadingPointName": {
     "type": "cds.String",
     "length": 25,
     "@sap.label": "Unloading Point"
    },
    "ControllingArea": {
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Controlling Area"
    },
    "CostObject": {
     "type": "cds.String",
     "length": 12,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Cost Object"
    },
    "ProfitCenter": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Profit Center"
    },
    "ProjectNetwork": {
     "type": "cds.String",
     "length": 12,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Network",
     "@sap.quickinfo": "Network Number for Account Assignment"
    },
    "RealEstateObject": {
     "type": "cds.String",
     "length": 8,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Real Estate Key",
     "@sap.quickinfo": "Internal Key of Real Estate Object (FI)"
    },
    "PartnerAccountNumber": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Partner",
     "@sap.quickinfo": "Partner account number"
    },
    "CommitmentItem": {
     "type": "cds.String",
     "length": 24,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Commitment Item"
    },
    "JointVentureRecoveryCode": {
     "type": "cds.String",
     "length": 2,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Recovery Indicator"
    },
    "FundsCenter": {
     "type": "cds.String",
     "length": 16,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Funds Center"
    },
    "FunctionalArea": {
     "type": "cds.String",
     "length": 16,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Functional Area"
    },
    "SettlementReferenceDate": {
     "type": "cds.Date",
     "@sap.display.format": "Date",
     "@sap.label": "Reference Date",
     "@sap.quickinfo": "Reference date for settlement"
    },
    "TaxCode": {
     "type": "cds.String",
     "length": 2,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Tax Code",
     "@sap.quickinfo": "Tax on Sales/Purchases Code"
    },
    "TaxJurisdiction": {
     "type": "cds.String",
     "length": 15,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Tax Jurisdiction"
    },
    "NonDeductibleInputTaxAmount": {
     "type": "cds.Decimal",
     "precision": 13,
     "scale": 3,
     "@sap.unit": "DocumentCurrency",
     "@sap.variable.scale": "true",
     "@sap.label": "Non-deductible",
     "@sap.quickinfo": "Non-deductible input tax"
    },
    "CostCtrActivityType": {
     "type": "cds.String",
     "length": 6,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Activity Type"
    },
    "BusinessProcess": {
     "type": "cds.String",
     "length": 12,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Business Process"
    },
    "EarmarkedFundsDocument": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Earmarked Funds",
     "@sap.quickinfo": "Document Number for Earmarked Funds"
    },
    "GrantID": {
     "type": "cds.String",
     "length": 20,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Grant"
    },
    "BudgetPeriod": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Budget Period"
    },
    "WBSElementExternalID": {
     "type": "cds.String",
     "length": 24,
     "@sap.display.format": "UpperCase",
     "@sap.label": "WBS Element",
     "@sap.quickinfo": "Work Breakdown Structure Element (WBS Element) Edited"
    }
   }
  },
  "API_PURCHASECONTRACT_PROCESS_SRV_0002.A_PurCtrAddress": {
