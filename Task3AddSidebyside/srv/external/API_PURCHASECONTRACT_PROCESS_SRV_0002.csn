  "API_PURCHASECONTRACT_PROCESS_SRV_0002.A_PurchaseContractItemNotes": {
   "kind": "entity",
   "@cds.external": true,
   "@cds.persistence.skip": true,
   "@sap.deletable": "false",
   "@sap.content.version": "2",
   "@sap.label": "Item Notes",
   "elements": {
    "Language": {
     "key": true,
     "type": "cds.String",
     "length": 2,
     "@sap.label": "Language Key",
     "notNull": true
    },
    "TextObjectType": {
     "key": true,
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Text ID",
     "notNull": true
    },
    "ArchitecturalObjectNumber": {
     "key": true,
     "type": "cds.String",
     "length": 70,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Text Name",
     "@sap.quickinfo": "Name",
     "notNull": true
    },
    "TechnicalObjectType": {
     "key": true,
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Text object",
     "@sap.quickinfo": "Texts: application object",
     "notNull": true
    },
    "PurchaseContractItem": {
     "key": true,
     "type": "cds.String",
     "length": 5,
     "@sap.display.format": "NonNegative",
     "@sap.label": "Item",
     "@sap.quickinfo": "Item Number of Purchasing Document",
     "notNull": true
    },
    "PurchaseContract": {
     "key": true,
     "type": "cds.String",
     "length": 10,
     "notNull": true
    },
    "NoteDescription": {
     "type": "cds.String",
     "@sap.label": "Long Text"
    },
    "FixedIndicator": {
     "type": "cds.String",
     "length": 1,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Fixing",
     "@sap.quickinfo": "&quot;Fixed&quot; Indicator for Texts"
    }
   }
  },
  "API_PURCHASECONTRACT_PROCESS_SRV_0002.A_PurchaseContractItem": {
   "kind": "entity",
   "@cds.external": true,
   "@cds.persistence.skip": true,
   "@sap.deletable": "false",
   "@sap.content.version": "2",
   "@sap.label": "Purchase Contract Item",
   "elements": {
    "PurchaseContract": {
     "key": true,
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Purchase Contract",
     "@sap.quickinfo": "Purchasing Contract Header",
     "@sap.value.list": "standard",
     "notNull": true
    },
    "PurchaseContractItem": {
     "key": true,
     "type": "cds.String",
     "length": 5,
     "@sap.display.format": "NonNegative",
     "@sap.label": "Item",
     "@sap.quickinfo": "Item Number of Purchasing Contract",
     "notNull": true
    },
    "PurchasingContractDeletionCode": {
     "type": "cds.String",
     "length": 1,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Deletion Indicator",
     "@sap.quickinfo": "Deletion Indicator in Purchasing Document"
    },
    "PurchaseContractItemText": {
     "type": "cds.String",
     "length": 40,
     "@sap.label": "Short Text"
    },
    "CompanyCode": {
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Company Code"
    },
    "Plant": {
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Plant"
    },
    "StorageLocation": {
     "type": "cds.String",
     "length": 4,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Storage Location"
    },
    "RequirementTracking": {
     "type": "cds.String",
     "length": 10,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Req. Tracking Number",
     "@sap.quickinfo": "Requirement Tracking Number"
    },
    "MaterialGroup": {
     "type": "cds.String",
     "length": 9,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Material Group"
    },
    "SupplierMaterialNumber": {
     "type": "cds.String",
     "length": 35,
     "@sap.display.format": "UpperCase",
     "@sap.label": "Supplier Mat. No.",
     "@sap.quickinfo": "Material Number Used by Supplier"
    },
    "OrderQuantityUnit": {
     "type": "cds.String",
     "length": 3,
     "@sap.label": "Order Unit",
     "@sap.quickinfo": "Purchase Order Unit of Measure",
     "@sap.semantics": "unit-of-measure"
    },
    "OrderQuantityUnitISOCode": {
     "type": "cds.String",
     "length": 3,
     "@sap.display.format": "UpperCase",
     "@sap.label": "ISO Code",
     "@sap.quickinfo": "ISO Code for Unit of Measurement"
    },
    "TargetQuantity": {
     "type": "cds.Decimal",
     "precision": 13,
     "scale": 3,
     "@sap.unit": "OrderQuantityUnit",
     "@sap.label": "Target Quantity"
    },
    "PurgDocReleaseOrderQuantity": {
     "type": "cds.Decimal",
     "precision": 13,
     "scale": 3,
     "@sap.unit": "OrderQuantityUnit",
     "@sap.label": "Stand.Rel.Order.Qty.",
     "@sap.quickinfo": "Standard release order quantity"
    },
    "OrderPriceUnit": {
     "type": "cds.String",
     "length": 3,
     "@sap.label": "Order Price Unit",
     "@sap.quickinfo": "Order Price Unit (Purchasing)",
     "@sap.semantics": "unit-of-measure"
    },
    "OrderPriceUnitISOCode": {
     "type": "cds.String",
     "length": 3,
     "@sap.display.format": "UpperCase",
     "@sap.label": "ISO Code",
     "@sap.quickinfo": "ISO Code for Unit of Measurement"
    },
    "OrderPriceUnitToOrderUnitNmrtr": {
     "type": "cds.Decimal",
     "precision": 5,
     "scale": 0,
     "@sap.label": "Qty. Conv. Numerator",
     "@sap.quickinfo": "Numerator for Conversion of Order Price Unit into Order Unit"
    },
    "OrdPriceUnitToOrderUnitDnmntr": {
     "type": "cds.Decimal",
     "precision": 5,
     "scale": 0,
     "@sap.label": "Quantity Conversion",
     "@sap.quickinfo": "Denominator for Conv. of Order Price Unit into Order Unit"
    },
    "ContractNetPriceAmount": {
     "type": "cds.Decimal",
     "precision": 11,
     "scale": 3,
     "@sap.unit": "DocumentCurrency",
     "@sap.variable.scale": "true",
     "@sap.label": "Net Order Price",
     "@sap.quickinfo": "Net Price in Purchasing Document (in Document Currency)"
