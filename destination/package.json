{
  "name": "destination",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "kind": "mocked",
      "BankAPI": {
        "kind": "rest",
        "credentials": {
          "destination": "DealerAPI",
          "forwardAuthToken": true
        }
      },
      "StateAPI": {
        "kind": "odata-v4",
        "credentials": {
          "destination": "StateAPI",
          "forwardAuthToken": true
        }
      }
    }
  }
}
